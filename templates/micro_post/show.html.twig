{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
    <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">{{ post.title }}</h1>
        <p class="text-gray-700 dark:text-gray-300 mb-6 leading-relaxed">{{ post.text }}</p>
        <div class="flex items-center gap-3 mb-2">
            <a href="{{ path('app_user_profile', {id: post.author.id}) }}">
                {% if post.author.userProfile and post.author.userProfile.image %}
                    <img src="/uploads/avatars/{{ post.author.userProfile.image }}"
                         alt="{{ post.author.email }}"
                         class="w-8 h-8 rounded-full object-cover">
                {% else %}
                    <div class="w-8 h-8 rounded-full bg-indigo-600 flex items-center justify-center text-white font-bold text-xs">
                        {{ post.author.email|first|upper }}
                    </div>
                {% endif %}
            </a>
            <p class="text-sm text-gray-500 dark:text-gray-400">By: <a href="{{ path('app_user_profile', {id: post.author.id}) }}" class="text-indigo-600 dark:text-indigo-400 hover:underline">{{ post.author.email }}</a></p>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Created: {{ post.created|date('Y-m-d H:i:s') }}</p>
        <div class="flex gap-3 items-center">
            <form action="{{ path('app_micro_post_like', {id: post.id}) }}" method="post">
                <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-pink-500 hover:bg-pink-600 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
                    Like ({{ post.likes }})
                </button>
            </form>
            {% if app.user and app.user.id == post.author.id %}
                <a href="{{ path('app_micro_post_edit', {id: post.id}) }}" class="px-5 py-2.5 bg-amber-500 hover:bg-amber-600 text-white rounded-lg text-sm font-medium transition-colors">Edit</a>
            {% endif %}
            <a href="{{ path('app_micro_post') }}" class="px-5 py-2.5 bg-gray-500 hover:bg-gray-600 text-white rounded-lg text-sm font-medium transition-colors">Back to list</a>
        </div>
    </div>

    <div class="mt-8 bg-white dark:bg-gray-800 p-8 rounded-xl shadow">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">
            Comments ({{ post.comments|length }})
        </h2>

        {% if post.comments|length > 0 %}
            <div class="relative mb-8">
                {% for comment in post.comments %}
                    <div class="relative flex gap-4 {% if not loop.last %}pb-8{% endif %}">
                        {% if not loop.last %}
                            <div class="absolute left-5 top-10 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-600"></div>
                        {% endif %}
                        {% if comment.author.userProfile and comment.author.userProfile.image %}
                            <img src="/uploads/avatars/{{ comment.author.userProfile.image }}"
                                 alt="{{ comment.authorName|default('A') }}"
                                 class="shrink-0 w-10 h-10 rounded-full object-cover z-10 border-2 border-white dark:border-gray-800">
                        {% else %}
                            <div class="shrink-0 w-10 h-10 rounded-full bg-indigo-500 dark:bg-indigo-600 flex items-center justify-center text-white font-semibold text-sm z-10 border-2 border-white dark:border-gray-800">
                                {{ comment.authorName|default('A')|first|upper }}
                            </div>
                        {% endif %}
                        <div class="flex-1 min-w-0">
                            <div class="mb-1">
                                <a href="{{ path('app_user_profile', {id: comment.author.id}) }}" class="block font-semibold text-indigo-600 dark:text-indigo-400 hover:underline text-sm">{{ comment.authorName|default('Anonymous') }}</a>
                                <span class="block text-xs text-gray-400 dark:text-gray-500">{{ comment.createdAt ? comment.createdAt|date('M d, Y \\a\\t H:i') : '' }}</span>
                            </div>
                            <p class="text-gray-700 dark:text-gray-300">{{ comment.text }}</p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-gray-500 dark:text-gray-400 mb-8">No comments yet. Be the first to comment!</p>
        {% endif %}

        <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Add a comment</h3>
            {{ form_start(comment_form, {'attr': {'novalidate': 'novalidate'}}) }}
                <div class="mb-4">
                    {{ form_widget(comment_form.text, {'attr': {'class': 'w-full px-3 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent min-h-[80px] resize-y', 'placeholder': 'Write your comment...'}}) }}
                    {{ form_errors(comment_form.text) }}
                </div>
                {{ form_widget(comment_form.submit, {'attr': {'class': 'px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer'}}) }}
            {{ form_end(comment_form) }}
        </div>
    </div>
{% endblock %}