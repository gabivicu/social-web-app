{% extends 'base.html.twig' %}

{% block title %}Micro Posts{% endblock %}

{% block body %}
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Micro Posts</h1>
        {% if is_granted('ROLE_VERIFIED') %}
            <a href="{{ path('app_micro_post_create') }}" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-sm font-medium transition-colors">
                Create new post
            </a>
        {% endif %}
    </div>

    <div class="overflow-hidden rounded-xl shadow bg-white dark:bg-gray-800">
        <table class="w-full">
            <thead>
                <tr class="bg-indigo-600 text-white text-left">
                    <th class="px-4 py-3 font-semibold">ID</th>
                    <th class="px-4 py-3 font-semibold">Title</th>
                    <th class="px-4 py-3 font-semibold">Author</th>
                    <th class="px-4 py-3 font-semibold">Text</th>
                    <th class="px-4 py-3 font-semibold">Created</th>
                    <th class="px-4 py-3 font-semibold">Comments</th>
                    <th class="px-4 py-3 font-semibold">Likes</th>
                    <th class="px-4 py-3 font-semibold">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                {% for post in posts %}
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                        <td class="px-4 py-3">{{ post.id }}</td>
                        <td class="px-4 py-3">
                            <a href="{{ path('app_micro_post_show', {id: post.id}) }}" class="text-indigo-600 dark:text-indigo-400 hover:underline">
                                {{ post.title }}
                            </a>
                        </td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ post.author.email }}</td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ post.text|length > 50 ? post.text|slice(0, 50) ~ '...' : post.text }}</td>
                        <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-sm">{{ post.created|date('Y-m-d H:i') }}</td>
                        <td class="px-4 py-3 text-gray-600 dark:text-gray-400">{{ post.comments|length }}</td>
                        <td class="px-4 py-3">
                            <form action="{{ path('app_micro_post_like', {id: post.id}) }}" method="post" class="inline">
                                <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-pink-500 hover:bg-pink-600 text-white rounded text-sm font-medium transition-colors cursor-pointer">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
                                    {{ post.likes }}
                                </button>
                            </form>
                        </td>
                        <td class="px-4 py-3">
                            {% if app.user and app.user.id == post.author.id %}
                                <a href="{{ path('app_micro_post_edit', {id: post.id}) }}" class="px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-white rounded text-sm font-medium transition-colors">
                                    Edit
                                </a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="px-4 py-8 text-center text-gray-500 dark:text-gray-400">No micro posts found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}