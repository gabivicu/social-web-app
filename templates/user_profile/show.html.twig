{% extends 'base.html.twig' %}

{% set displayName = profile and profile.name ? profile.name : user.email %}

{% block title %}{{ displayName }} - Profile{% endblock %}

{% block body %}
    {# Profile Header Card #}
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden mb-8">
        <div class="h-32 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500"></div>
        <div class="px-8 pb-8">
            <div class="flex flex-col sm:flex-row items-center sm:items-end gap-4 -mt-12">
                <div class="shrink-0 w-24 h-24 rounded-full bg-indigo-600 flex items-center justify-center text-white text-4xl font-bold ring-4 ring-white dark:ring-gray-800 shadow-lg">
                    {{ user.email|first|upper }}
                </div>
                <div class="flex-1 text-center sm:text-left sm:pb-1">
                    <h1 class="text-2xl font-bold">{{ displayName }}</h1>
                    <p class="text-sm text-gray-500 dark:text-gray-400">{{ user.email }}</p>
                </div>
                {% if app.user and app.user.id == user.id %}
                    <a href="{{ path('app_settings') }}" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors">
                        Edit Profile
                    </a>
                {% endif %}
            </div>

            {% if profile and profile.bio %}
                <p class="mt-6 text-gray-700 dark:text-gray-300 leading-relaxed max-w-2xl">{{ profile.bio }}</p>
            {% endif %}

            {% if profile %}
                <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
                    {% if profile.company %}
                        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                            <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                            </svg>
                            <span>{{ profile.company }}</span>
                        </div>
                    {% endif %}
                    {% if profile.location %}
                        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                            <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            <span>{{ profile.location }}</span>
                        </div>
                    {% endif %}
                    {% if profile.websiteUrl %}
                        <div class="flex items-center gap-2 text-sm">
                            <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                            </svg>
                            <a href="{{ profile.websiteUrl }}" target="_blank" rel="noopener" class="text-indigo-600 dark:text-indigo-400 hover:underline truncate">{{ profile.websiteUrl }}</a>
                        </div>
                    {% endif %}
                    {% if profile.twitterUsername %}
                        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                            <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                            </svg>
                            <span>@{{ profile.twitterUsername }}</span>
                        </div>
                    {% endif %}
                    {% if profile.dateOfBirth %}
                        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                            <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <span>{{ profile.dateOfBirth|date('F d, Y') }}</span>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

    {# Stats Bar #}
    <div class="grid grid-cols-3 gap-4 mb-8">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-5 text-center">
            <p class="text-3xl font-bold text-indigo-600 dark:text-indigo-400">{{ posts|length }}</p>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Posts</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-5 text-center">
            <p class="text-3xl font-bold text-pink-500">{{ user.comments|length }}</p>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Comments</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-5 text-center">
            {% set totalLikes = 0 %}
            {% for post in posts %}
                {% set totalLikes = totalLikes + post.likes %}
            {% endfor %}
            <p class="text-3xl font-bold text-amber-500">{{ totalLikes }}</p>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Likes Received</p>
        </div>
    </div>

    {# Posts Section #}
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
        <div class="px-8 py-5 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-lg font-bold">Posts</h2>
        </div>

        {% if posts|length > 0 %}
            <div class="divide-y divide-gray-200 dark:divide-gray-700">
                {% for post in posts %}
                    <a href="{{ path('app_micro_post_show', {id: post.id}) }}" class="block px-8 py-5 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                        <div class="flex items-start justify-between gap-4">
                            <div class="min-w-0 flex-1">
                                <h3 class="font-semibold text-gray-900 dark:text-white mb-1">{{ post.title }}</h3>
                                <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2">{{ post.text|length > 200 ? post.text|slice(0, 200) ~ '...' : post.text }}</p>
                            </div>
                            <div class="shrink-0 flex items-center gap-3 text-xs text-gray-400 dark:text-gray-500">
                                <span class="flex items-center gap-1">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                                    {{ post.comments|length }}
                                </span>
                                <span class="flex items-center gap-1">
                                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
                                    {{ post.likes }}
                                </span>
                            </div>
                        </div>
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">{{ post.created|date('M d, Y \\a\\t H:i') }}</p>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="px-8 py-12 text-center">
                <svg class="w-12 h-12 mx-auto text-gray-300 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                </svg>
                <p class="text-gray-500 dark:text-gray-400">No posts yet.</p>
            </div>
        {% endif %}
    </div>
{% endblock %}
