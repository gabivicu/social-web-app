{% extends 'base.html.twig' %}

{% block title %}Settings{% endblock %}

{% block body %}
    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}

    {# ── Profile Image Section ── #}
    <div class="max-w-2xl mx-auto bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 mb-6">
        <h2 class="text-xl font-bold mb-6">Profile Image</h2>

        <div class="flex items-center gap-8">
            {# Current avatar preview #}
            <div class="shrink-0 p-2">
                {% if profile is defined and profile.image %}
                    <img src="/uploads/avatars/{{ profile.image }}"
                         alt="Profile image"
                         class="w-24 h-24 rounded-full object-cover ring-4 ring-indigo-100 dark:ring-gray-700 shadow-lg">
                {% else %}
                    <div class="w-24 h-24 rounded-full bg-indigo-600 flex items-center justify-center text-white text-4xl font-bold ring-4 ring-indigo-100 dark:ring-gray-700 shadow-lg">
                        {{ app.user.email|first|upper }}
                    </div>
                {% endif %}
            </div>

            <div class="flex-1 min-w-0">
                {{ form_label(form.imageFile, null, {'label_attr': {'class': 'block text-sm font-medium mb-2'}}) }}
                {{ form_widget(form.imageFile, {'attr': {'class': 'block w-full text-sm text-gray-500 dark:text-gray-400
                    file:mr-4 file:py-2 file:px-4
                    file:rounded-lg file:border-0
                    file:text-sm file:font-medium
                    file:bg-indigo-50 file:text-indigo-700
                    dark:file:bg-indigo-900/30 dark:file:text-indigo-400
                    hover:file:bg-indigo-100 dark:hover:file:bg-indigo-900/50
                    file:cursor-pointer file:transition-colors'}}) }}
                {{ form_errors(form.imageFile) }}
                <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">JPEG, PNG or WebP. Max 2MB.</p>
            </div>
        </div>
    </div>

    {# ── Profile Details Section ── #}
    <div class="max-w-2xl mx-auto bg-white dark:bg-gray-800 rounded-lg shadow-md p-8">
        <h2 class="text-xl font-bold mb-6">Profile Settings</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                {{ form_label(form.name, null, {'label_attr': {'class': 'block text-sm font-medium mb-1'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500', 'placeholder': 'Your name'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div>
                {{ form_label(form.twitterUsername, null, {'label_attr': {'class': 'block text-sm font-medium mb-1'}}) }}
                {{ form_widget(form.twitterUsername, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500', 'placeholder': '@username'}}) }}
                {{ form_errors(form.twitterUsername) }}
            </div>

            <div>
                {{ form_label(form.company, null, {'label_attr': {'class': 'block text-sm font-medium mb-1'}}) }}
                {{ form_widget(form.company, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500', 'placeholder': 'Company name'}}) }}
                {{ form_errors(form.company) }}
            </div>

            <div>
                {{ form_label(form.location, null, {'label_attr': {'class': 'block text-sm font-medium mb-1'}}) }}
                {{ form_widget(form.location, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500', 'placeholder': 'City, Country'}}) }}
                {{ form_errors(form.location) }}
            </div>

            <div class="md:col-span-2">
                {{ form_label(form.websiteUrl, null, {'label_attr': {'class': 'block text-sm font-medium mb-1'}}) }}
                {{ form_widget(form.websiteUrl, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500', 'placeholder': 'https://example.com'}}) }}
                {{ form_errors(form.websiteUrl) }}
            </div>

            <div class="md:col-span-2">
                {{ form_label(form.bio, null, {'label_attr': {'class': 'block text-sm font-medium mb-1'}}) }}
                {{ form_widget(form.bio, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 min-h-[100px] resize-y', 'placeholder': 'Tell us about yourself...'}}) }}
                {{ form_errors(form.bio) }}
            </div>

            <div>
                {{ form_label(form.dateOfBirth, null, {'label_attr': {'class': 'block text-sm font-medium mb-1'}}) }}
                {{ form_widget(form.dateOfBirth, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
                {{ form_errors(form.dateOfBirth) }}
            </div>
        </div>

        <div class="mt-6">
            {{ form_widget(form.save, {'attr': {'class': 'px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors cursor-pointer'}}) }}
        </div>
    </div>

    {{ form_end(form) }}
{% endblock %}
